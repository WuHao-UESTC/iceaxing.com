---
import { getCollection } from 'astro:content';
// 🌟 优化 1：引入我们之前构思的公共基座
import Base from '../../layouts/Base.astro';

const allPosts = await getCollection('analog_ic');

const projectsMap = new Map();
allPosts.forEach((post) => {
  if (!projectsMap.has(post.data.projectId)) {
    projectsMap.set(post.data.projectId, post.data.projectName);
  }
});
const uniqueProjects = Array.from(projectsMap.entries());
---

<Base title="Analog IC 知识库" description="Analog IC 学习路线与项目归档">
  <div class="project-hub">
    <h1 class="hub-title">Analog IC 知识库</h1>
    <p class="hub-subtitle">请在下方选择进入具体的项目版块：</p>

    <ul class="project-list">
      {uniqueProjects.map(([projectId, projectName]) => (
        <li class="project-card">
          <a href={`/analog_ic/${projectId}/`}>
            <h2>{projectName}</h2>
            <p>点击进入该项目，查看仿真附件与所有子模块博客 ➡️</p>
          </a>
        </li>
      ))}
    </ul>
  </div>
</Base>

<style>
  .project-hub {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem;
  }
  .hub-title {
    text-align: center;
    color: #ff5d01;
  }
  .hub-subtitle {
    text-align: center;
    margin-bottom: 2rem;
  }
  .project-list {
    display: flex;
    gap: 2rem;
    list-style: none;
    padding: 0;
  }
  .project-card {
    border: 1px solid #ddd;
    padding: 1.5rem;
    border-radius: 8px;
    width: 100%;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  /* 甚至可以顺手加一个鼠标悬浮的高级特效！ */
  .project-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
  }
  .project-card a {
    text-decoration: none;
    color: #333;
    display: block; /* 让整个卡片区域都可点击 */
  }
</style>