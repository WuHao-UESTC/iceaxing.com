---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';  //引入公共布局组件
import ProjectCard from '../../components/ProjectCard.astro';

const allPosts = await getCollection('analog_ic');  //获取所有项目博客
const uniqueProjectIds = [...new Set(allPosts.map((post) => post.data.projectId))]; //获取所有唯一的项目 ID

/******************************************************
 * uniqueProjects提取并传输的参量
 * 项目 ID project.id
 * 项目名称 project.name  
 * 项目描述 project.description
 ******************************************************/
const uniqueProjects = uniqueProjectIds.map((projectId) => {
  // 过滤出所有与当前项目 ID 相关的博客
  const projectPosts = allPosts.filter((post) => post.data.projectId === projectId);
  // 找出一篇带有 projectName 或 projectDesc的intro.md文件
  const introPost = projectPosts.find((post) => post.data.projectName || post.data.projectDesc);

  return {
    id: projectId,
    // 如果找到了且有名字，就用这个漂亮的名字；否则，用底层的 projectId 兜底（防崩溃）
    name: (introPost && introPost.data.projectName) ? introPost.data.projectName : projectId,
    // 如果找到了描述就用，没有就给默认文本
    description: (introPost && introPost.data.projectDesc) ? introPost.data.projectDesc : "点击进入该项目，查看详情与仿真附件..."
  };
});
---

<Base title="Analog IC 知识库" description="Analog IC 学习路线与项目归档">
  <div class="project-hub">
    <h1 class="hub-title">Analog IC 知识库</h1>
    <p class="hub-subtitle">请在下方选择进入具体的项目版块：</p>

    <ul class="project-list">
      {uniqueProjects.map((project) => (
        <ProjectCard
          name={project.name}
          description={project.description}
          href={`/analog_ic/${project.id}/`}
          category="analog_ic"
        />
      ))}
    </ul>
  </div>
</Base>

<style>
  .project-hub {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem;
  }
  .hub-title {
    text-align: center;
    color: #ff5d01;
  }
  .hub-subtitle {
    text-align: center;
    margin-bottom: 2rem;
  }
  .project-list {
    display: flex;
    gap: 2rem;
    list-style: none;
    padding: 0;
  }
  .project-card {
    border: 1px solid #ddd;
    padding: 1.5rem;
    border-radius: 8px;
    width: 100%;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  /* 甚至可以顺手加一个鼠标悬浮的高级特效！ */
  .project-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
  }
  .project-card a {
    text-decoration: none;
    color: #333;
    display: block; /* 让整个卡片区域都可点击 */
  }
</style>