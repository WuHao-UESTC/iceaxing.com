---
import { getCollection } from 'astro:content';

import Base from '../../../layouts/Base.astro';
import DownloadCard from '../../../components/DownloadCard.astro';
import FormatDate from '../../../components/FormattedDate.astro';
import ArticleCard from '../../../components/ArticleCard.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('analog_ic');
  const uniqueProjectIds = [...new Set(allPosts.map((post) => post.data.projectId))];
  
  return uniqueProjectIds.map((projectId) => {
    const projectPosts = allPosts.filter((post) => post.data.projectId === projectId);

    // 从intro.md文件中提取项目名称
    const introPost = projectPosts.find((post) => post.data.projectName || post.data.projectDesc);
    const safeProjectName = introPost? introPost.data.projectName : projectId;

    return {
      params: { project: projectId },
      props: { 
        posts: projectPosts, 
        projectName: safeProjectName
      },
    };
  });
}

const { project } = Astro.params;
const { posts, projectName } = Astro.props;
---

<Base title={`${projectName} `} description={`关于 ${projectName} 的所有内容`}>
  <div class="project-container">
    <h1 class="project-title">{projectName} </h1>
    
    <DownloadCard 
      title={`${projectName} 完整仿真资源包 (.tar.gz)`} 
      fileUrl={`/assets/files/${project}-pack.zip`} 
    />

    <section class="module-section">
      <h2 class="section-subtitle">Modules</h2>
      <ul class="article-list">
        {posts.map((post) => {
          const articleSlug = post.id.split('/')[1]; 
          return (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              href={`/analog_ic/${project}/${articleSlug}/`}
              category="analog_ic"
            />
          );
        })}
      </ul>
    </section>
  </div>
</Base>

<style>
  .project-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 1rem 0;
  }
  .project-title {
    font-size: 2.2rem;
    color: #1a1a1a;
    margin-bottom: 2rem;
  }
  .section-subtitle {
    font-size: 1.5rem;
    border-bottom: 2px solid #eee;
    padding-bottom: 0.5rem;
    margin-bottom: 1.5rem;
  }
  .article-list {
    list-style: none;
    padding: 0;
  }
  .article-item {
    margin-bottom: 1.5rem;
    padding: 1rem;
    border-radius: 8px;
    background-color: transparent;
    transition: background-color 0.2s ease;
  }
  .article-item:hover {
    background-color: #fff8f5; /* 悬浮时的淡橙色背景 */
  }
  .article-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .article-link h3 {
    margin: 0 0 0.5rem 0;
    color: #ff5d01;
    font-size: 1.25rem;
  }
  .article-link p {
    margin: 0;
    font-size: 0.9rem;
    color: #666;
    line-height: 1.6;
  }
</style>